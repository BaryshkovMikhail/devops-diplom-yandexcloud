# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# Секреты и ключи
*.pem
*.key
*.secret
credentials.json

# Локальные конфиги
.kube/
*.log
.DS_Store
# Terraform sensitive files
**/*.tfplan
**/*.tfplan.json
**/*.tfstate
**/*.tfstate.*
**/*.tfvars
!**/*.tfvars.example
**/.terraform/
**/.terraform.lock.hcl

# Outputs with sensitive data
*-outputs.json
